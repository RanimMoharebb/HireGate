###################################


@baseUrl = http://localhost:5106
@topicId = 5
@deleteQuestionId = 28
@deleteTopicId = 4
@questionId = 29

### 1) Get all topics
GET {{baseUrl}}/api/admin/topics/
Accept: application/json

### 2) Create topic
POST {{baseUrl}}/api/admin/topics/
Content-Type: application/json
Accept: application/json

{
  "topicName": "OSSSS"
}

### 3) Get topic by id
GET {{baseUrl}}/api/admin/topics/{{topicId}}
Accept: application/json

### 5) Delete topic
DELETE {{baseUrl}}/api/admin/topics/{{topicId}}
Accept: application/json

### 6) Verify deleted topic (should be 404)
GET {{baseUrl}}/api/admin/topics/{{topicId}}
Accept: application/json
###############################################################


### 1) Get all questions (admin) ------------------------------- CORRECT
GET {{baseUrl}}/api/admin/questions/
Accept: application/json

### 2) Create question (admin) ------------------------------- CORRECT
POST {{baseUrl}}/api/admin/questions/
Content-Type: application/json
Accept: application/json

{
  "topicId": {{topicId}},
  "questionText": "What is Big O of binary search?",
  "questionImage": "https://cdn.example.com/questions/binary-search.png",
  "choices": [
    {
      "choiceText": "O(log n)",
      "isCorrect": true
    },
    {
      "choiceText": "O(n)",
      "isCorrect": false
    }
  ]
}

### 3) Get question by id (admin) ------------ CORRECT
GET {{baseUrl}}/api/admin/questions/{{questionId}}
Accept: application/json

### 4) Get questions by topic id (admin) ---------CORRECT
GET {{baseUrl}}/api/admin/questions/topic/{{topicId}}
Accept: application/json

### 5) Update question (admin)   --------------CORRECT
PUT {{baseUrl}}/api/admin/questions/{{questionId}}
Content-Type: application/json
Accept: application/json

{
  "topicId": {{topicId}},
  "questionText": "What is the time complexity of binary search?",
  "questionImage": null,
  "choices": [
    {
      "choiceText": "O(log n)",
      "isCorrect": true
    },
    {
      "choiceText": "O(n log n)",
      "isCorrect": false
    }
  ]
}

### 6) Patch question text only (admin, partial update)
PATCH {{baseUrl}}/api/admin/questions/{{questionId}}
Content-Type: application/json
Accept: application/json

{
  "questionText": "Binary search runs in what complexity?"
}

### 7) Patch question choices only (admin, partial update)// can be 2 correct
PATCH {{baseUrl}}/api/admin/questions/{{questionId}}
Content-Type: application/json
Accept: application/json

{
  "choices": [
    {
      "choiceText": "O(log nNNN)",
      "isCorrect": true
    },
    {
      "choiceText": "O(n)",
      "isCorrect": false
    },
    {
      "choiceText": "O(n)",
      "isCorrect": false
    }
  ]
}

### 8) Clear question image (admin, partial update) --- wrong
PATCH {{baseUrl}}/api/admin/questions/{{questionId}}
Content-Type: application/json
Accept: application/json

{
  "questionImage": "https://cdn.example.com/questions/binary-search.png"
}

### 9) Delete question (admin) ------CORRECT
DELETE {{baseUrl}}/api/admin/questions/{{questionId}}
Accept: application/json

### 10) Verify deleted question (admin, should be 404)
GET {{baseUrl}}/api/admin/questions/{{questionId}}
Accept: application/json

###############################################################
@choiceId = 30
@invalidQuestionId = 99999
@invalidChoiceId = 99999

### 11) Add single choice to question (max 4 choices)
POST {{baseUrl}}/api/admin/questions/{{questionId}}/choices/
Content-Type: application/json
Accept: application/json

{
  "choiceText": "O(1)",
  "isCorrect": false
}

### 12) Add correct choice to question
POST {{baseUrl}}/api/admin/questions/{{questionId}}/choices/
Content-Type: application/json
Accept: application/json

{
  "choiceText": "O(log n) in balanced conditions",
  "isCorrect": true
}

### 13) Add choice with empty text (should be 400)
POST {{baseUrl}}/api/admin/questions/{{questionId}}/choices/
Content-Type: application/json
Accept: application/json

{
  "choiceText": "",
  "isCorrect": false
}

### 14) Add choice to invalid question (should be 404)
POST {{baseUrl}}/api/admin/questions/{{invalidQuestionId}}/choices/
Content-Type: application/json
Accept: application/json

{
  "choiceText": "Invalid question choice",
  "isCorrect": false
}

### 15) Add beyond max choices (run after question already has 4, should be 400)
POST {{baseUrl}}/api/admin/questions/{{questionId}}/choices/
Content-Type: application/json
Accept: application/json

{
  "choiceText": "Extra choice should fail",
  "isCorrect": false
}

### 16) Full update single choice
PUT {{baseUrl}}/api/admin/questions/{{questionId}}/choices/{{choiceId}}
Content-Type: application/json
Accept: application/json

{
  "choiceText": "O(log n) average case",
  "isCorrect": true
}

### 17) Full update with invalid choice id (should be 404)
PUT {{baseUrl}}/api/admin/questions/{{questionId}}/choices/{{invalidChoiceId}}
Content-Type: application/json
Accept: application/json

{
  "choiceText": "Should fail",
  "isCorrect": false
}

### 18) Full update with empty text (should be 400)
PUT {{baseUrl}}/api/admin/questions/{{questionId}}/choices/{{choiceId}}
Content-Type: application/json
Accept: application/json

{
  "choiceText": "   ",
  "isCorrect": false
}

### 19) Partial update single choice (isCorrect only)
PATCH {{baseUrl}}/api/admin/questions/{{questionId}}/choices/{{choiceId}}
Content-Type: application/json
Accept: application/json

{
  "isCorrect": false
}

### 20) Partial update single choice (text only)
PATCH {{baseUrl}}/api/admin/questions/{{questionId}}/choices/{{choiceId}}
Content-Type: application/json
Accept: application/json

{
  "choiceText": "Updated by patch"
}

### 21) Partial update with empty text (should be 400)
PATCH {{baseUrl}}/api/admin/questions/{{questionId}}/choices/{{choiceId}}
Content-Type: application/json
Accept: application/json

{
  "choiceText": ""
}

### 22) Partial update invalid choice id (should be 404)
PATCH {{baseUrl}}/api/admin/questions/{{questionId}}/choices/{{invalidChoiceId}}
Content-Type: application/json
Accept: application/json

{
  "isCorrect": true
}

### 23) Delete single choice from question
DELETE {{baseUrl}}/api/admin/questions/{{questionId}}/choices/{{choiceId}}
Accept: application/json

### 24) Delete invalid choice id (should be 404)
DELETE {{baseUrl}}/api/admin/questions/{{questionId}}/choices/{{invalidChoiceId}}
Accept: application/json

### 25) Delete from invalid question id (should be 404)
DELETE {{baseUrl}}/api/admin/questions/{{invalidQuestionId}}/choices/{{choiceId}}
Accept: application/json

### 26) Delete until less than minimum choices (run repeatedly, final should be 400)
DELETE {{baseUrl}}/api/admin/questions/{{questionId}}/choices/{{choiceId}}
Accept: application/json

### 27) Change only question text after choice operations
PATCH {{baseUrl}}/api/admin/questions/{{questionId}}
Content-Type: application/json
Accept: application/json

{
  "questionText": "After choice operations, question is still editable"
}

### 28) Verify question after choice operations
GET {{baseUrl}}/api/admin/questions/{{questionId}}
Accept: application/json


### 8) Update topic
PUT {{baseUrl}}/api/admin/topics/{{topicId}}
Content-Type: application/json
Accept: application/json

{
  "topicName": "Data Structures"
}


